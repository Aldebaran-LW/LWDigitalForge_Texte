# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# GitHub (opcional, aumenta limites e permite repos privados via token)
GITHUB_TOKEN=

# Google (opcional)
# Uma destas opções:
# 1) JSON inteiro em uma única variável:
GOOGLE_APPLICATION_CREDENTIALS_JSON=
# 2) Caminho no runtime (se você provisionar arquivo no deploy):
GOOGLE_APPLICATION_CREDENTIALS=

# Segurança do cron
CRON_SHARED_SECRET=

# Config
ANALYSIS_MAX_FILES=2000
ANALYSIS_MAX_BYTES=5000000
