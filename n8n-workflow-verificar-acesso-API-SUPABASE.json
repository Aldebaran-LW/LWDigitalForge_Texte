    {
      "parameters": {
        "jsCode": "// ============================================\n// LÓGICA DE VERIFICAÇÃO DE ACESSO\n// ============================================\n\nconst userId = $('2. Extrair userId e appId').item.json.user_id;\nconst appId = $('2. Extrair userId e appId').item.json.app_id;\n\n// Obter dados das análises\nconst comprasData = $('6. Analisar Compras').item.json;\nconst trialsData = $('7. Analisar Trials').item.json;\n\n// Parsear JSON\nconst compras = JSON.parse(comprasData.purchases_data || '[]');\nconst trials = JSON.parse(trialsData.trials_data || '[]');\n\nconsole.log('📊 Total compras:', compras.length);\nconsole.log('📊 Total trials:', trials.length);\n\n// Variáveis de resultado\nlet hasAccess = false;\nlet accessType = null;\nlet expiresAt = null;\nlet reason = null;\n\n// ============================================\n// 1. VERIFICAR LIFETIME (Prioridade Máxima)\n// ============================================\nfor (const compra of compras) {\n  if (compra.purchase_type === 'LIFETIME') {\n    hasAccess = true;\n    accessType = 'LIFETIME';\n    reason = 'Compra LIFETIME encontrada';\n    console.log('✅ LIFETIME encontrado!');\n    break;\n  }\n}\n\n// ============================================\n// 2. VERIFICAR ASSINATURAS (MONTHLY/ANNUAL)\n// ============================================\nif (!hasAccess) {\n  const now = new Date();\n  \n  for (const compra of compras) {\n    if (['MONTHLY', 'ANNUAL'].includes(compra.purchase_type)) {\n      const expDate = compra.expires_at ? new Date(compra.expires_at) : null;\n      \n      if (expDate && expDate > now) {\n        hasAccess = true;\n        accessType = compra.purchase_type;\n        expiresAt = compra.expires_at;\n        reason = `Assinatura ${compra.purchase_type} ativa até ${expDate.toLocaleDateString()}`;\n        console.log(`✅ Assinatura ${compra.purchase_type} válida!`);\n        break;\n      } else {\n        console.log(`⚠️ Assinatura ${compra.purchase_type} expirada`);\n      }\n    }\n  }\n}\n\n// ============================================\n// 3. VERIFICAR TRIAL\n// ============================================\nif (!hasAccess && trials.length > 0) {\n  const trial = trials[0]; // Primeiro trial ativo\n  hasAccess = true;\n  accessType = 'TRIAL';\n  expiresAt = trial.expires_at;\n  const expDate = new Date(trial.expires_at);\n  reason = `Trial ativo até ${expDate.toLocaleDateString()}`;\n  console.log('✅ Trial ativo encontrado!');\n}\n\n// ============================================\n// 4. SEM ACESSO\n// ============================================\nif (!hasAccess) {\n  reason = 'Nenhuma compra, assinatura ou trial ativo encontrado';\n  console.log('❌ Sem acesso');\n}\n\n// ============================================\n// RETORNO\n// ============================================\nreturn {\n  userId,\n  appId,\n  hasAccess,\n  accessType,\n  expiresAt,\n  reason,\n  debug: {\n    totalCompras: compras.length,\n    totalTrials: trials.length,\n    comprasTypes: compras.map(c => c.purchase_type),\n    timestamp: new Date().toISOString()\n  }\n};"
      },
