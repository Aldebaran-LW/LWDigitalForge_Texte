    {
      "parameters": {
        "jsCode": "// Extrair variáveis de ambiente\nconst supabaseUrl = process.env.SUPABASE_URL || 'https://wwwwyuwighdehmvnolrl.supabase.co';\nconst supabaseKey = process.env.SUPABASE_SERVICE_ROLE_KEY;\n\n// Validar se a chave está configurada\nif (!supabaseKey) {\n  throw new Error('SUPABASE_SERVICE_ROLE_KEY não configurada no Render. Configure a variável de ambiente.');\n}\n\n// Passar dados do nó anterior + variáveis de ambiente\nreturn {\n  ...$input.item.json,\n  supabase_url: supabaseUrl,\n  supabase_key: supabaseKey\n};"
      },
