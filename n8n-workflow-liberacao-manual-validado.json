      "id": "70f8545b-5ab4-4f24-a959-bede1dfec756",
      "name": "Verificar Compra Existente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1504,
        720
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "// Verificar se já existe trial ativo\nconst trialExistente = Array.isArray($input.item.json) ? $input.item.json[0] : $input.item.json;\nconst dados = $('Mesclar App e Validar').item.json;\n\nif (trialExistente && trialExistente.id) {\n  const expiresAt = new Date(trialExistente.expires_at);\n  return {\n    json: {\n      ...dados,\n      trial_existente: true,\n      trial_id: trialExistente.id,\n      trial_expires_at: trialExistente.expires_at,\n      aviso: `Usuário já possui trial ativo que expira em ${expiresAt.toLocaleString('pt-BR')}`\n    }\n  };\n}\n\nreturn {\n  json: {\n    ...dados,\n    trial_existente: false\n  }\n};"
      },
      "id": "22588243-6d16-4863-8711-86b37f89d81f",
      "name": "Validar Trial",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1712,
        512
      ]
    },
    {
      "parameters": {
        "jsCode": "// Verificar se já existe compra ativa\nconst compraExistente = Array.isArray($input.item.json) ? $input.item.json[0] : $input.item.json;\nconst dados = $('Mesclar App e Validar').item.json;\n\nif (compraExistente && compraExistente.id) {\n  const expiresAt = compraExistente.expires_at ? new Date(compraExistente.expires_at) : null;\n  return {\n    json: {\n      ...dados,\n      compra_existente: true,\n      compra_id: compraExistente.id,\n      compra_type: compraExistente.purchase_type,\n      compra_expires_at: compraExistente.expires_at,\n      aviso: compraExistente.purchase_type === 'LIFETIME' \n        ? 'Usuário já possui compra vitalícia!' \n        : `Usuário já possui ${compraExistente.purchase_type} ativa${expiresAt ? ' que expira em ' + expiresAt.toLocaleString('pt-BR') : ''}`\n    }\n  };\n}\n\nreturn {\n  json: {\n    ...dados,\n    compra_existente: false\n  }\n};"
      },
      "id": "1923dddb-bed1-492d-bf14-6ae2c04142ac",
      "name": "Validar Compra",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1712,
        720
      ]
    },
    {
      "parameters": {
        "jsCode": "// Calcular data de expiração do trial\nconst dados = $input.item.json;\nconst agora = new Date();\nconst diasTrial = dados.dias || dados.app_trial_period_days || 7;\nconst expiresAt = new Date();\nexpiresAt.setDate(expiresAt.getDate() + diasTrial);\n\nreturn {\n  json: {\n    user_id: dados.user_id,\n    app_id: dados.app_id,\n    started_at: agora.toISOString(),\n    expires_at: expiresAt.toISOString(),\n    is_active: true\n  }\n};"
      },
      "id": "9ad5d31f-d464-42d7-9de3-d9abe020c434",
      "name": "Preparar Trial",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1920,
        512
      ]
    },
    {
      "parameters": {
        "jsCode": "// Calcular data de expiração da compra\nconst dados = $input.item.json;\nconst tipo = dados.tipo.toUpperCase();\nconst agora = new Date();\nlet expiresAt;\n\nif (tipo === 'LIFETIME') {\n  expiresAt = '2099-01-01T00:00:00.000Z';\n} else {\n  expiresAt = new Date();\n  if (dados.dias) {\n    expiresAt.setDate(expiresAt.getDate() + dados.dias);\n  } else if (tipo === 'MONTHLY') {\n    expiresAt.setMonth(expiresAt.getMonth() + 1);\n  } else if (tipo === 'ANNUAL') {\n    expiresAt.setFullYear(expiresAt.getFullYear() + 1);\n  }\n  expiresAt = expiresAt.toISOString();\n}\n\nreturn {\n  json: {\n    user_id: dados.user_id,\n    app_id: dados.app_id,\n    purchase_type: tipo,\n    status: 'APPROVED',\n    expires_at: expiresAt,\n    created_at: agora.toISOString()\n  }\n};"
      },
