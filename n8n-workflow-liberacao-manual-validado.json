    {
      "parameters": {
        "jsCode": "// Mesclar dados do app e validar\nconst app = Array.isArray($input.item.json) ? $input.item.json[0] : $input.item.json;\nconst dadosAnteriores = $('Mesclar Usuário').item.json;\n\nif (!app || !app.id) {\n  throw new Error('App não encontrado!');\n}\n\nif (!app.is_active) {\n  throw new Error(`App ${app.name} não está ativo!`);\n}\n\nreturn {\n  json: {\n    ...dadosAnteriores,\n    app_id: app.id,\n    app_name: app.name,\n    app_is_active: app.is_active,\n    app_trial_period_days: app.trial_period_days\n  }\n};"
      },
