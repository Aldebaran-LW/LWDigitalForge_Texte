# ========================================
# CONFIGURAÇŐES DO PROJETO
# ========================================
# Copie este arquivo para .env e preencha com suas credenciais reais

# ========================================
# SUPABASE
# ========================================
# URL do projeto Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co

# Chave pública (anon key) do Supabase
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ========================================
# MERCADO PAGO
# ========================================
# Chave pública do MercadoPago (para checkout)
VITE_MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key_here

# ========================================
# HOSTINGER ECOMMERCE API
# ========================================
# URL da API do Ecommerce (já configurada no código)
# VITE_ECOMMERCE_API_URL=https://api-ecommerce.hostinger.com

# ID da loja no Hostinger Ecommerce (já configurada no código)
# VITE_ECOMMERCE_STORE_ID=store_01K892AACBYD4WGW9R3SA50S3X

# ========================================
# DESENVOLVIMENTO
# ========================================
# Porta do servidor de desenvolvimento
# VITE_PORT=3000

# Modo de desenvolvimento (true/false)
# VITE_DEV_MODE=true
