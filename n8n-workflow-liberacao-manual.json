      "parameters": {
        "jsCode": "// Mesclar dados do usuário com dados anteriores\nconst usuario = Array.isArray($input.item.json) ? $input.item.json[0] : $input.item.json;\nconst dadosAnteriores = $('Coletar Dados').item.json;\n\nreturn {\n  json: {\n    ...dadosAnteriores,\n    user_id: usuario.id,\n    user_email: usuario.email,\n    user_name: usuario.full_name\n  }\n};"
