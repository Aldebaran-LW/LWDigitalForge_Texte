      "parameters": {
        "jsCode": "// Mesclar dados do app com dados anteriores\nconst app = Array.isArray($input.item.json) ? $input.item.json[0] : $input.item.json;\nconst dadosAnteriores = $('Mesclar Usuário').item.json;\n\nreturn {\n  json: {\n    ...dadosAnteriores,\n    app_id: app.id,\n    app_name: app.name,\n    app_is_active: app.is_active,\n    app_trial_period_days: app.trial_period_days\n  }\n};"
      },
