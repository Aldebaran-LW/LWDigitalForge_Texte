    {
      "parameters": {
        "jsCode": "// Calcular data de expiração do trial\nconst dados = $input.item.json;\nconst agora = new Date();\nconst diasTrial = dados.dias || dados.app_trial_period_days || 7;\nconst expiresAt = new Date();\nexpiresAt.setDate(expiresAt.getDate() + diasTrial);\n\nreturn {\n  json: {\n    user_id: dados.user_id,\n    app_id: dados.app_id,\n    started_at: agora.toISOString(),\n    expires_at: expiresAt.toISOString(),\n    is_active: true\n  }\n};"
      },
      "id": "preparar-trial",
      "name": "Preparar Trial",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        48,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "// Calcular data de expiração da compra\nconst dados = $input.item.json;\nconst tipo = dados.tipo.toUpperCase();\nconst agora = new Date();\nlet expiresAt;\n\nif (tipo === 'LIFETIME') {\n  expiresAt = '2099-01-01T00:00:00.000Z';\n} else {\n  expiresAt = new Date();\n  if (dados.dias) {\n    expiresAt.setDate(expiresAt.getDate() + dados.dias);\n  } else if (tipo === 'MONTHLY') {\n    expiresAt.setMonth(expiresAt.getMonth() + 1);\n  } else if (tipo === 'ANNUAL') {\n    expiresAt.setFullYear(expiresAt.getFullYear() + 1);\n  }\n  expiresAt = expiresAt.toISOString();\n}\n\nreturn {\n  json: {\n    user_id: dados.user_id,\n    app_id: dados.app_id,\n    purchase_type: tipo,\n    status: 'APPROVED',\n    expires_at: expiresAt,\n    created_at: agora.toISOString()\n  }\n};"
      },
